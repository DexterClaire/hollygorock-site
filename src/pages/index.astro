---
import Base from '../layouts/Base.astro';

const projects = [
  {
    tag: 'music / audio',
    title: 'Tuesday Nights Live',
    desc: 'Cover band. We play the songs. You know the songs.',
    href: '#',
  },
  {
    tag: 'radio',
    title: 'P25 Scanner',
    desc: 'OP25 on Raspberry Pi with custom hardware controls and a PiOLED display.',
    href: '#',
  },
  {
    tag: 'code tools',
    title: 'Vinyl Scrobbler',
    desc: 'Shazam-powered Last.fm scrobbling from a turntable, via Python and a Pi.',
    href: '#',
  },
  {
    tag: 'retro computing',
    title: 'Pentium MMX 200 Build',
    desc: 'Period-correct Win95 machine, built from an estate-sale AT mini-tower.',
    href: '#',
  },
  {
    tag: 'NES dev',
    title: '16-Step Sequencer',
    desc: 'A music toy written in NES assembly. Bass, melody, drums, chord progressions.',
    href: '#',
  },
  {
    tag: 'speedrunning',
    title: 'speedrun.com/hollygorock',
    desc: 'Times posted. Splits logged. No further comment.',
    href: 'https://speedrun.com/hollygorock',
  },
];
---

<Base>
  <main>
    <!-- ── Header ── -->
    <header class="site-header">
      <div class="container">
        <div class="header-inner">
          <p class="pixel site-logo">hollygorock</p>
          <nav class="site-nav mono">
            <a href="https://last.fm/user/dexterclaire" target="_blank" rel="noopener">last.fm</a>
            <a href="https://speedrun.com/hollygorock" target="_blank" rel="noopener">speedrun</a>
            <a href="https://twitter.com/hollygorock" target="_blank" rel="noopener">@hollygorock</a>
          </nav>
        </div>
      </div>
    </header>

    <!-- ── Hero ── -->
    <section class="hero">
      <div class="container">
        <h1 class="hero-headline mono">
          maker of things.<br />
          <span class="gold">player of songs.</span>
        </h1>
        <p class="hero-sub">
          Atlanta. IT by day. Drums, code, radio, vinyl, and retro computers by night.
        </p>
      </div>
    </section>

    <div class="container">
      <hr class="rule" />
    </div>

    <!-- ── Projects ── -->
    <section class="projects-section">
      <div class="container">
        <h2 class="section-label mono muted">projects &amp; interests</h2>
        <ul class="project-grid">
          {projects.map((p) => (
            <li class="project-card">
              <span class="card-tag pixel">{p.tag}</span>
              <h3 class="card-title">
                {p.href && p.href !== '#'
                  ? <a href={p.href} target="_blank" rel="noopener">{p.title}</a>
                  : p.title}
              </h3>
              <p class="card-desc muted">{p.desc}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <div class="container">
      <hr class="rule" />
    </div>

    <!-- ── Footer ── -->
    <footer class="site-footer">
      <div class="container">
        <p class="mono muted">
          hollygorock · atlanta, ga ·
          <a href="mailto:nick@hollygorock.com">nick@hollygorock.com</a>
        </p>
      </div>
    </footer>
  </main>
</Base>

<style>
/* ── Header ── */
.site-header {
  padding-block: 1.75rem;
  border-bottom: 1px solid var(--rule);
}
.header-inner {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}
.site-logo {
  font-size: 0.7rem;
  color: var(--gold);
  letter-spacing: 0.05em;
  line-height: 1.4;
}
.site-nav {
  display: flex;
  gap: 1.5rem;
  font-size: 0.8rem;
}
.site-nav a {
  text-decoration: none;
  color: var(--muted);
}
.site-nav a:hover { color: var(--gold); }

/* ── Hero ── */
.hero {
  padding-block: 4rem 3rem;
}
.hero-headline {
  font-size: clamp(1.4rem, 4vw, 2.2rem);
  font-weight: 700;
  line-height: 1.35;
  letter-spacing: -0.01em;
  margin-bottom: 1rem;
}
.gold { color: var(--gold); }
.hero-sub {
  font-size: 1.1rem;
  color: var(--muted);
  max-width: 48ch;
}

/* ── Projects ── */
.projects-section { padding-block: 1rem 4rem; }
.section-label {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 2rem;
}
.project-grid {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.25rem;
}
.project-card {
  background: var(--card-bg);
  border: 1px solid var(--rule);
  padding: 1.25rem 1.5rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.card-tag {
  font-size: 0.5rem;
  color: var(--gold-dim);
  letter-spacing: 0.06em;
  line-height: 1.6;
}
.card-title {
  font-family: var(--font-body);
  font-size: 1.05rem;
  font-weight: 600;
  line-height: 1.3;
}
.card-title a { text-decoration: none; color: var(--ink); }
.card-title a:hover { color: var(--gold-dim); }
.card-desc { font-size: 0.9rem; line-height: 1.6; }

/* ── Footer ── */
.site-footer {
  padding-block: 2rem 2.5rem;
  border-top: 1px solid var(--rule);
}
.site-footer p { font-size: 0.8rem; }

/* ── Mobile ── */
@media (max-width: 520px) {
  .site-nav { gap: 1rem; font-size: 0.75rem; }
  .hero { padding-block: 2.5rem 2rem; }
}
</style>
